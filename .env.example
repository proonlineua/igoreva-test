# Server
PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://beauty_user:password@localhost:5432/beauty_os

# Auth
JWT_SECRET=generate_with_node_-e_"console.log(require('crypto').randomBytes(32).toString('hex'))"

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Payments — Wayforpay
WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_account
WAYFORPAY_SECRET_KEY=your_secret_key
WAYFORPAY_MERCHANT_DOMAIN=your-domain.com
PLAN_PRICE=2999

# Email (optional — for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
